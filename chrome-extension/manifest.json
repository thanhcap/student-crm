{
  "manifest_version": 3,
  "name": "Relationship CRM Capture",
  "version": "1.0",
  "description": "Add a LinkedIn profile to your Relationship CRM in one click.",
  "permissions": ["storage"],
  "host_permissions": ["https://www.linkedin.com/*", "https://*.supabase.co/*"],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": { "default_title": "Relationship CRM" }
}
